# Example .env for the backend server
# Set your Google generative API key and model name (ej: models/text-bison-001 or gemini-alpha)
GOOGLE_API_KEY=
GOOGLE_MODEL=
PORT=3000

# (Opcional) Credenciales de API oficial de Mercado Libre Developers
# Si se configuran, la app usará búsquedas oficiales y rápidas en lugar del scraper de fallback
ML_CLIENT_ID=
ML_CLIENT_SECRET=
